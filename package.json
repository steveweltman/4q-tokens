{
  "name": "4q-tokenz",
  "mcpName": "io.github.steveweltman/4q-tokenz",
  "version": "1.18.0",
  "description": "MCP Proxy Gateway - Intelligent proxy that reduces token usage by exposing only mcp_search and mcp_call",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-proxy": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "echo 'No tests configured'",
    "test:cov": "echo 'No tests configured'",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "mcp",
    "proxy",
    "gateway",
    "token-reduction",
    "llm",
    "ai",
    "arvore"
  ],
  "author": "Steve Weltman (fork of @arvoretech/mcp-proxy by Árvore Educação)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/steveweltman/4q-tokens.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.22.4"
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.15.2"
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
