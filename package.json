  "author": "Arvore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arvoreeducacao/arvore-mcp-servers.git",
    "directory": "packages/mcp-proxy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.22.0",
    "@xenova/transformers": "^2.17.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
