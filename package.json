    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "echo 'No tests configured'",
    "test:cov": "echo 'No tests configured'",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
